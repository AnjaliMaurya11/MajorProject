<% layout("/layouts/boilerplate") %>

<div class="container my-4">

  <!-- Title & Subtitle -->
  <h1><%= listing.title %></h1>
  <p class="text-muted">
    <%= listing.location %>, <%= listing.country %> &nbsp;·&nbsp;
    <%= listing.reviews.length %> reviews
  </p>

  <!-- Image -->
  <div class="image-wrapper">
   <img
    src="<%= listing.image.url %>"
    class="listing-img"
    src="<%= listing.image.url %>"
    alt="listing-image"
   />
  </div>

  <div class="row mt-4">

    <!-- LEFT SIDE — Details -->
    <div class="col-lg-7">

      <!-- Host Info -->
      <div class="d-flex align-items-center gap-3 py-3 border-top border-bottom mb-3">
        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:48px; height:48px; font-weight:500;">
          <%= listing.owner.username[0].toUpperCase() %>
        </div>
        <div>
          <p class="mb-0 fw-500">Hosted by <i><%= listing.owner.username %></i></p>
          <p class="mb-0 text-muted" style="font-size:13px;">Owner</p>
        </div>
      </div>

      <!-- Info Badges -->
      <div class="d-flex gap-3 flex-wrap mb-3">
        <span class="text-muted" style="font-size:14px;"><%= listing.location %>, <%= listing.country %></span>
        <span class="text-muted" style="font-size:14px;">₹<%= listing.price.toLocaleString("en-IN") %> / night</span>
      </div>

      <!-- Description -->
      <p class="text-muted"><%= listing.description %></p>

      <hr/>


      <!-- Reviews -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Reviews</h4>
        <span class="text-muted"><%= listing.reviews.length %> reviews</span>
      </div>

      <div class="row">
        <% for(let review of listing.reviews){ %>
          <div class="col-md-6 mb-3">
            <div class="card h-100">
              <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center" style="width:36px; height:36px; font-size:12px;">
                    <%= review.author.username[0].toUpperCase() %>
                  </div>
                  <div>
                    <p class="mb-0 fw-500" style="font-size:14px;"><%= review.author.username %></p>
                    <p class="starability-result mb-0" data-rating="<%= review.rating %>"></p>
                  </div>
                </div>
                <p class="text-muted mb-0" style="font-size:13px;"><%= review.comment %></p>
              </div>
              <% if(currentUser && review.author._id.equals(currentUser._id)){ %>
                <div class="card-footer">
                  <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if(listing.reviews.length === 0){ %>
          <p class="text-muted">No reviews yet. Be the first to review!</p>
        <% } %>
      </div>

      <!-- Leave Review -->
      <% if(currentUser && !listing.owner._id.equals(currentUser._id)){ %>
        <div class="bg-light rounded p-3 mt-3">
          <h5>Leave a review</h5>
          <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
            <div class="mb-3">
              <label class="form-label">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked/>
                <input type="radio" id="second-rate1" name="review[rating]" value="1"/>
                <label for="second-rate1" title="Terrible">1 star</label>
                <input type="radio" id="second-rate2" name="review[rating]" value="2"/>
                <label for="second-rate2" title="Not good">2 stars</label>
                <input type="radio" id="second-rate3" name="review[rating]" value="3"/>
                <label for="second-rate3" title="Average">3 stars</label>
                <input type="radio" id="second-rate4" name="review[rating]" value="4"/>
                <label for="second-rate4" title="Very good">4 stars</label>
                <input type="radio" id="second-rate5" name="review[rating]" value="5"/>
                <label for="second-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>
            <div class="mb-3">
              <label class="form-label">Comment</label>
              <textarea name="review[comment]" class="form-control" rows="4" required></textarea>
              <div class="invalid-feedback">Please enter a comment.</div>
            </div>
            <button class="btn btn-outline-dark">Submit review</button>
          </form>
        </div>
      <% } %>

      <!-- Edit/Delete -->
      <% if(currentUser && listing.owner._id.equals(currentUser._id)){ %>
        <div class="d-flex gap-2 mt-3">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark">Edit listing</a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-outline-danger">Delete listing</button>
          </form>
        </div>
      <% } %>

    </div>

    <!-- Booking Card -->
    <div class="col-lg-4 offset-lg-1 booking-card">
       <div class="card shadow-sm">
         <div class="card-body p-4">
          <h5 class="mb-3">
           ₹<%= listing.price.toLocaleString("en-IN") %>
           <span class="fw-normal fs-6 text-muted">/ night</span>
          </h5>
          <form method="GET" action="/listings/<%= listing._id %>/bookings/new">
           <div class="row g-0 border rounded mb-3">
             <div class="col-6 p-2 border-end">
               <label class="form-label fw-bold">Check-in</label>
               <input type="date" name="checkIn" class="form-control border-0 p-0"
                min="<%= new Date().toISOString().split('T')[0] %>" required/>
             </div>
             <div class="col-6 p-2">
               <label class="form-label fw-bold">Check-out</label>
               <input type="date" name="checkOut" class="form-control border-0 p-0"
               min="<%= new Date().toISOString().split('T')[0] %>" required/>
             </div>
           </div>
           <div class="border rounded p-2 mb-3">
             <label class="form-label fw-bold mb-0">Guests</label>
             <input type="number" name="guests" class="form-control border-0 p-0" min="1" max="10"
              placeholder="Enter number of guests" required/>
           </div>
            <!-- Different button based on login status -->
           <% if(currentUser){ %>
             <% if(listing.owner._id.equals(currentUser._id)){ %>
               <!-- Owner -->
               <button class="btn w-100 mb-2 btn-secondary" disabled>
                 You own this listing
               </button>
              <% } else { %>
               <!-- Logged in user -->
               <button class="btn w-100 mb-2 text-white" style="background:#fe424d;" type="submit">
                 Reserve
               </button>
              <% } %>
            <% } else { %>
              <!-- Not logged in  -->
              <button type="button" class="btn w-100 mb-2 text-white" style="background:#fe424d;"
               data-bs-toggle="modal" data-bs-target="#loginModal" data-redirect="/listings/<%= listing._id %>">
               Login to Reserve
              </button>
            <% } %>
             <p class="text-center text-muted" style="font-size:12px;">You won't be charged yet</p>
          </form>     
         </div>
       </div>
     </div>
  </div>
</div>

